# ============================================================
# VARIABLES D'ENVIRONNEMENT — LUXE.MA
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# SERVER
PORT=3000
NODE_ENV=production

# JWT Secret — changer en production!
JWT_SECRET=votre_super_secret_jwt_ici_change_moi

# ── MYSQL (Railway fournit ces variables automatiquement) ──
MYSQLHOST=your-mysql-host.railway.internal
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=votre_mot_de_passe_mysql
MYSQLDATABASE=shopdb
